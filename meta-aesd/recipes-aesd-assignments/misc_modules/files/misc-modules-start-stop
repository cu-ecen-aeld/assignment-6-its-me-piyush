#!/bin/sh

HELLO_KO="/lib/modules/$(uname -r)/extra/hello.ko"
FAULTY_KO="/lib/modules/$(uname -r)/extra/faulty.ko"

is_loaded() { lsmod | awk '{print $1}' | grep -qx "$1"; }

wait_for_major() {
    name="$1"; tries="${2:-30}"; delay="${3:-0.1}"
    while [ "$tries" -gt 0 ]; do
        major="$(awk -v n="$name" '$2==n {print $1}' /proc/devices)"
        [ -n "$major" ] && { echo "$major"; return 0; }
        tries=$((tries - 1))
        sleep "$delay"
    done
    return 1
}

case "$1" in
start)
    echo "Loading misc modules"

    if ! is_loaded hello; then
        insmod "$HELLO_KO" 2>/dev/null || modprobe hello 2>/dev/null || {
            echo "ERROR: failed to load hello"; exit 1; }
        echo "Loaded hello"
    else
        echo "hello already loaded"
    fi

    if ! is_loaded faulty; then
        insmod "$FAULTY_KO" 2>/dev/null || modprobe faulty 2>/dev/null || {
            echo "ERROR: failed to load faulty"; exit 1; }
        echo "Loaded faulty"
    else
        echo "faulty already loaded"
    fi

    if [ ! -e /dev/faulty ]; then
        major="$(wait_for_major faulty 30 0.1)" || {
            echo "ERROR: could not find major for faulty in /proc/devices"
            exit 1
        }
        mknod /dev/faulty c "$major" 0
        chmod 666 /dev/faulty
        echo "Created /dev/faulty (c $major 0)"
    fi
    ;;
stop)
    rm -f /dev/faulty
    is_loaded faulty && rmmod faulty || true
    is_loaded hello && rmmod hello || true
    ;;
status)
    is_loaded hello && echo "hello: loaded" || echo "hello: not loaded"
    is_loaded faulty && echo "faulty: loaded" || echo "faulty: not loaded"
    [ -e /dev/faulty ] && echo "/dev/faulty: present" || echo "/dev/faulty: missing"
    ;;
*)
    echo "Usage: $0 {start|stop|status}"
    exit 1
esac
exit 0
